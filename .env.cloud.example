# =============================================================================
# Cloud Deployment Environment Variables
# =============================================================================
# Copy to .env and fill in your values:
#   cp .env.cloud.example .env
# =============================================================================

# --- Database (Neon free tier) -----------------------------------------------
# Get this from: https://console.neon.tech → Project → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxxxx.us-east-2.aws.neon.tech/news_tracker?sslmode=require

# Reduce pool size for Neon free tier connection limits
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=5

# --- Redis (runs locally in Docker, no config needed) ------------------------
# REDIS_URL is set in docker-compose.cloud.yml

# --- API Server --------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8001

# Generate a secure key: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty for dev mode (no auth)
API_KEYS=

# Set to your Vercel frontend URL for production
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true
REQUEST_TIMEOUT_SECONDS=30

# --- Ingestion ---------------------------------------------------------------
# Increase poll interval to reduce Neon compute-hour usage
POLL_INTERVAL_SECONDS=3600

# Platform API keys (add as needed)
# TWITTER_BEARER_TOKEN=
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# NEWSFILTER_API_KEYS=key1,key2
# MARKETAUX_API_KEYS=key1,key2
# FINLIGHT_API_KEYS=key1,key2

# Sotwe scraping (no API key needed)
SOTWE_ENABLED=true
# SOTWE_USERNAMES=user1,user2

# --- Processing --------------------------------------------------------------
SPAM_THRESHOLD=0.7
DUPLICATE_THRESHOLD=0.85

# --- ML Models (CPU inference on ARM) ----------------------------------------
EMBEDDING_MODEL_NAME=ProsusAI/finbert
MINILM_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
EMBEDDING_USE_FP16=false
EMBEDDING_BATCH_SIZE=16
EMBEDDING_CACHE_ENABLED=true
EMBEDDING_CACHE_TTL_HOURS=168

SENTIMENT_MODEL_NAME=ProsusAI/finbert
SENTIMENT_DEVICE=cpu
SENTIMENT_USE_FP16=false
SENTIMENT_BATCH_SIZE=8

# --- Feature Flags (all disabled by default, enable as needed) ---------------
# NER_ENABLED=true
# KEYWORDS_ENABLED=true
# EVENTS_ENABLED=true
# CLUSTERING_ENABLED=true
# ALERTS_ENABLED=true
# NOTIFICATIONS_ENABLED=true
# GRAPH_ENABLED=true
# PROPAGATION_ENABLED=true
# AUTHORITY_ENABLED=true
# SECURITY_MASTER_ENABLED=true
# SOURCES_ENABLED=true
# FEEDBACK_ENABLED=true
# BACKTEST_ENABLED=true
# SCORING_ENABLED=true
# DRIFT_ENABLED=true
# WS_ALERTS_ENABLED=true
# RATE_LIMIT_ENABLED=true

# --- Observability (disabled for cloud, enable if using Grafana Cloud) -------
# TRACING_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=INFO
